define flow handle education
  user ask education
  $answer = execute rag_action
  $check_facts = True
  bot $answer
  stop

define flow handle unknown
  user unknown message
  $answer = execute rag_action
  $check_facts = True
  bot $answer
  stop

define flow self check facts
  $accuracy = execute self_check_facts
  if not $accuracy
    bot inform answer prone to hallucination
    stop