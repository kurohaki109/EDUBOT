# ── BOT RESPONSES ──
define bot refuse toxic
  "🚫 Mohon maaf, saya tidak bisa membantu dengan kata-kata seperti itu."

define bot refuse gen alpha slang
  "🚫 Mohon maaf, mari kita gunakan bahasa indonesia yang benar ya."

define bot refuse racist
  "🚫 Semua orang memiliki perbedaan masing-masing. Saya tidak bisa membantu dengan hal itu."

define bot refuse porn
  "🚫 Mohon maaf, saya tidak bisa membantu menjawab hal tersebut."

define bot refuse unsafe
  "🚫 Mohon maaf, saya tidak bisa membantu dengan hal itu."

define bot refuse off topic
  "🚫 Saya hanya bisa membantu materi pelajaran SD."

define bot unknown response
  "🚫 Maaf, aku tidak mengerti. Coba tanya tentang materi pelajaran ya! 😊"

define bot inform answer prone to hallucination
  "🚫 Maaf, jawaban ini tidak didukung oleh materi buku pelajaran."

# ── FLOWS ──
define flow handle toxic
  user express toxic
  bot refuse toxic
  stop

define flow handle gen alpha slang
  user express gen alpha slang
  bot refuse gen alpha slang
  stop

define flow handle racist
  user express racist
  bot refuse racist
